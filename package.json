{
  "name": "mindline",
  "version": "0.1.0",
  "description": "A secure P2P chat application with real-time typing indicators",
  "main": "index.js",
  "scripts": {
    "build-wasm": "wasm-pack build --target web",
    "build": "npm run build-wasm && webpack",
    "build:production": "npm run build-wasm && webpack --mode production",
    "build:cloudflare": "npm run build-wasm && webpack --mode production --env cloudflare=true",
    "start": "webpack serve",
    "serve": "http-server dist -p 8080 -c-1",
    "signaling": "node signaling-server.js",
    "start:production": "concurrently \"npm run serve\" \"npm run signaling\"",
    "deploy": "npm run build:production",
    "deploy:cloudflare": "npm run build:cloudflare",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "chat",
    "p2p",
    "wasm",
    "webrtc",
    "encryption"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "concurrently": "^7.6.0",
    "http-server": "^14.1.1",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@wasm-tool/wasm-pack-plugin": "^1.6.0",
    "css-loader": "^7.1.2",
    "html-webpack-plugin": "^5.5.0",
    "style-loader": "^4.0.0",
    "webpack": "^5.75.0",
    "webpack-cli": "^5.0.0",
    "webpack-dev-server": "^5.2.2"
  },
  "packageManager": "pnpm@9.15.0+sha512.76e2379760a4328ec4415815bcd6628dee727af3779aaa4c914e3944156c4299921a89f976381ee107d41f12cfa4b66681ca9c718f0668fa0831ed4c6d8ba56c"
}
