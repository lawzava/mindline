{
  "name": "mindline",
  "version": "0.1.0",
  "description": "A secure P2P chat application with real-time typing indicators",
  "main": "index.js",
  "scripts": {
    "build-wasm": "wasm-pack build --target web",
    "build": "npm run build-wasm && webpack --env development=true",
    "build:production": "npm run build-wasm && webpack --env production=true",
    "build:cloudflare": "./cloud_build.sh",
    "start": "webpack serve",
    "start-local": "webpack serve --port 8088",
    "logging": "node logging-server.js",
    "serve": "http-server dist -p 8080 -c-1",
    "signaling": "node signaling-server.js",
    "start:production": "concurrently \"npm run serve\" \"npm run signaling\"",
    "deploy": "npm run build:production",
    "deploy:cloudflare": "npm run build:cloudflare",
    "generate-icons": "node generate-icons.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "chat",
    "p2p",
    "wasm",
    "webrtc",
    "encryption"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.13",
    "autoprefixer": "^10.4.21",
    "concurrently": "^7.6.0",
    "copy-webpack-plugin": "^13.0.1",
    "css-loader": "^7.1.2",
    "html-webpack-plugin": "^5.5.0",
    "http-server": "^14.1.1",
    "mini-css-extract-plugin": "^2.9.4",
    "playwright": "^1.55.0",
    "postcss": "^8.5.6",
    "postcss-loader": "^8.2.0",
    "sharp": "^0.34.3",
    "style-loader": "^4.0.0",
    "tailwindcss": "^4.1.13",
    "wasm-pack": "^0.13.1",
    "webpack": "^5.75.0",
    "webpack-cli": "^5.0.0",
    "webpack-dev-server": "^5.2.2"
  },
  "packageManager": "pnpm@9.15.0+sha512.76e2379760a4328ec4415815bcd6628dee727af3779aaa4c914e3944156c4299921a89f976381ee107d41f12cfa4b66681ca9c718f0668fa0831ed4c6d8ba56c"
}
