{
  "name": "Mindline - Secure P2P Chat",
  "short_name": "Mindline",
  "id": "mindline-secure-p2p-chat",
  "description": "End-to-end encrypted peer-to-peer real-time chat with transparent typing",
  "start_url": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone"],
  "background_color": "#ffffff",
  "theme_color": "#5E81AC",
  "orientation": "portrait-primary",
  "scope": "/",
  "categories": ["social", "productivity", "communication"],
  "lang": "en",
  "dir": "ltr",
  "icons": [
    {
      "src": "/icons/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/icons/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "screenshots": [
    {
      "src": "/screenshots/desktop-chat.png",
      "sizes": "1280x720",
      "type": "image/png",
      "platform": "wide",
      "label": "Main chat interface showing secure P2P messaging"
    },
    {
      "src": "/screenshots/mobile-chat.png",
      "sizes": "375x667",
      "type": "image/png",
      "platform": "narrow",
      "label": "Mobile chat view with typing indicators"
    }
  ],
  "prefer_related_applications": false,
  "edge_side_panel": {
    "preferred_width": 400
  },
  "shortcuts": [
    {
      "name": "Join Random Room",
      "short_name": "Random",
      "description": "Join a random public room",
      "url": "/?action=random",
      "icons": [
        {
          "src": "/icons/icon-192x192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Create Room",
      "short_name": "Create",
      "description": "Create a new chat room",
      "url": "/?action=create",
      "icons": [
        {
          "src": "/icons/icon-192x192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    }
  ],
  "launch_handler": {
    "client_mode": "focus-existing"
  },
  "share_target": {
    "action": "/",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "widgets": [
    {
      "name": "Chat Status",
      "short_name": "Status",
      "description": "View current room status and recent messages",
      "tag": "chat-status",
      "template": "chat-status-template",
      "ms_ac_template": "adaptive-card.json",
      "data": "/widgets/chat-status",
      "type": "application/json",
      "screenshots": [
        {
          "src": "/screenshots/widget-chat-status.png",
          "sizes": "400x200",
          "label": "Chat status widget showing room activity"
        }
      ],
      "icons": [
        {
          "src": "/icons/icon-192x192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ],
      "auth": false,
      "update": 300000
    }
  ]
}