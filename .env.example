# Mindline environment variables
#
# Copy to `.env` and adjust. There are TWO processes with separate config:
#   1. the static web app (SvelteKit, built with @sveltejs/adapter-node)
#   2. the signaling/relay server (signaling-server.js, a Node WS server)
#
# `docker compose up --build` runs both: app on :8080, signaling on :9210.

# ──────────────────────────────────────────────────────────────────────────
# APP — BUILD-TIME (Vite `VITE_*` vars, baked into the bundle + CSP)
# ──────────────────────────────────────────────────────────────────────────
# These are read at build time and frozen into the static bundle. The app's
# Content-Security-Policy pins the signaling/TURN origins at build time, so
# changing any of these requires a REBUILD — they cannot be overridden at
# runtime. (A runtime `window.MINDLINE_ENV` override exists but is still
# constrained by the build-time CSP allowlist.)

# Signaling server the browser connects to. Either a bare host (`wss://` is
# assumed in production) or a full origin (`wss://...` / `ws://...` for local).
# Leave unset to derive it from the app's own hostname.
VITE_SIGNALING_SERVER=signal.example.com

# TURN servers for NAT traversal. No default is shipped (the old free tier was
# unreliable); provision your own for connectivity behind strict NATs. Without
# TURN, peers that can't form a direct path fall back to the encrypted relay.
# Comma-separated list of turn:/turns: URLs.
VITE_TURN_URLS=turns:turn.example.com:5349?transport=tcp,turn:turn.example.com:3478
VITE_TURN_USERNAME=turn-user
VITE_TURN_CREDENTIAL=turn-secret

# ──────────────────────────────────────────────────────────────────────────
# APP — RUNTIME (adapter-node server)
# ──────────────────────────────────────────────────────────────────────────
# Read by the Node server that serves the built app. In Docker this is 8080.
PORT=3000
HOST=0.0.0.0

# ──────────────────────────────────────────────────────────────────────────
# SIGNALING SERVER — RUNTIME (signaling-server.js)
# ──────────────────────────────────────────────────────────────────────────
# NOTE: PORT/HOST below are for the signaling process. When running both via
# docker compose, the signaling server uses 9210; standalone it defaults to
# 3000 (the same default the app uses in dev), so give each its own value.
PORT=3000
HOST=0.0.0.0

# Comma-separated list of browser origins allowed to open the WebSocket and
# call /health. An unknown Origin is rejected; non-browser clients that send
# no Origin (e.g. the soak test) are allowed through. Set this to your app's
# public origin(s) in production.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost:4173

# Rate limits (positive integers; invalid values fall back to the defaults).
# Per-client messages per second.
RATE_LIMIT_MESSAGES_PER_SECOND=50
# Per-IP connection attempts per minute (default 30 in dev, 240 in production).
RATE_LIMIT_CONNECTION_ATTEMPTS_PER_MINUTE=30
# Per-client room joins per minute.
RATE_LIMIT_ROOM_JOINS_PER_MINUTE=30
